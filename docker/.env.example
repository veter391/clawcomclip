# ClawComClip — Environment variables
# Copy to .env and fill in values before deployment

# Database password (required)
CLAWCOMCLIP_DB_PASSWORD=changeme_use_strong_password

# Auth mode: "local_trusted" (single user, loopback) or "authenticated" (multi-user)
CLAWCOMCLIP_AUTH_MODE=local_trusted

# Required only if CLAWCOMCLIP_AUTH_MODE=authenticated
# Generate with: openssl rand -hex 32
CLAWCOMCLIP_AUTH_SECRET=

# OpenClaw Gateway connection
OPENCLAW_GATEWAY_URL=http://host.docker.internal:18789
OPENCLAW_GATEWAY_TOKEN=your_openclaw_gateway_token_here
